---
// Ported from the legacy index.html body (nav/footer/forms/map extracted to
// components in Tasks 4-6). Task 7 landed this as a static port with no client
// behaviour wired up; Task 8 wires it all: scroll animations and the notification
// banners (src/scripts/animation.ts, imported globally from BaseLayout), the
// testimonials carousel (src/scripts/carousel.ts, imported below), and the service
// tabs (src/components/Tabs.astro, wrapping the tab markup in this file). The
// vendored npm packages (gsap, swiper) replace the removed CDN scripts and the deleted
// flextabs plugin.
//
// Section id rename (cross-task interface, see Nav.astro): the legacy
// `id="who-are-we"` / `id="why-us"` become `id="WhoAreWe"` / `id="WhyUs"` to
// match the anchors Nav/Footer already link to (`/#WhoAreWe`, `/#WhyUs`).
import ConsultForm from '../components/ConsultForm.astro';
import Map from '../components/Map.astro';
import Tabs from '../components/Tabs.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Immigrant Resource Center | Immigration & Travel Services in Minneapolis"
  description="Immigration and travel services in Minneapolis. Green card, citizenship, and visa
    application assistance."
  canonical="https://www.ircoffice.com/"
>
  <!--
    COVID notice banners, ported verbatim from index.html body content (homepage-only, not part
    of the shared Nav/Footer chrome per Task 4). GSAP entrance/exit animation and the close-icon
    click handlers are wired in src/scripts/animation.ts (imported globally from BaseLayout).
  -->
  <div class="top-notification" style="background: rgb(183, 94, 12);">
    <p class="paragraph-notification">
      For latest COVID-19 immigration announcements check at USCIS website.
    </p>
    <div class="notification-close" id="close-icon">×</div>
  </div>

  <div class="bottom-notification" style="background: rgb(183, 94, 12);">
    <p class="paragraph-notification pn-2">
      For latest COVID-19 immigration announcements check at USCIS website.
    </p>
    <div class="notification-close-2" id="close-icon-2">×</div>
  </div>

  <!--website hero image with form-->
  <header class="header-2 header--home">
    <div class="header-home__content header__home--animation flex-center">
      <h1 class="heading__primary align-middle my-25">
        Your <span class="secondary-color-text">one-stop center</span> for your Immigration needs
      </h1>
      <p class="header__paragraph align-middle my-25">
        Our skilled immigration experts are here to guide you throughout your immigration
        process, helping you get your application right and done quickly.
      </p>
      <a href="#WhyUs" class="btn btn--primary btn--animated">Learn More</a>
    </div>
  </header>

  <section class="section section__form">
    <div
      class="form-box form__home--animation"
      style="box-shadow: rgba(0, 0, 0, 0.25) 0 3px 11px 0;"
    >
      <h2 class="heading-form align-middle my-20">ASK OUR EXPERTS</h2>
      <p class="paragraph-form align-middle my-30">
        We are here to help you with your application process.
      </p>
      <ConsultForm subject="Consultation" formId="form__consultation" variant="orange" />
    </div>
  </section>
  <div class="divider"></div>

